    import re

def clean_text(text):

    text = text.lower()
    text = re.sub(r"[^a-z\s]", "", text)

    return text


def remove_stop_words(text):

    with open("./data/stop_words.py", "r") as file:
        stop_words = eval(file.read().split("=")[1])

    words = text.split()

    filtered = [word for word in words if word not in stop_words]

    return filtered


def check_text_similarity(file1, file2):

    with open(file1, "r", encoding="utf-8") as f:
        text1 = clean_text(f.read())

    with open(file2, "r", encoding="utf-8") as f:
        text2 = clean_text(f.read())

    words1 = set(remove_stop_words(text1))
    words2 = set(remove_stop_words(text2))

    common = words1.intersection(words2)

    similarity = (len(common) / len(words1.union(words2))) * 100

    return round(similarity,2)


print(check_text_similarity(
    "./data/michelle_obama_speech.txt",
    "./data/melina_trump_speech.txt"
),"%")
