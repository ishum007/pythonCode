import csv
import re

python_count = 0
javascript_count = 0
java_count = 0

with open("./data/hacker_news.csv", encoding="utf-8") as file:

    reader = csv.reader(file)

    next(reader)

    for row in reader:

        title = row[1]

        if re.search(r"\bpython\b", title, re.IGNORECASE):
            python_count += 1

        if re.search(r"\bjavascript\b", title, re.IGNORECASE):
            javascript_count += 1

        if re.search(r"\bjava\b", title, re.IGNORECASE) and not re.search(r"\bjavascript\b", title, re.IGNORECASE):
            java_count += 1

print("Python:", python_count)

print("JavaScript:", javascript_count)

print("Java (excluding JavaScript):", java_count)




























































































