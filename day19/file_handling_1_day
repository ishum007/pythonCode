import re

def extract_emails(filename):

    with open(filename, "r", encoding="utf-8") as file:
        text = file.read()

    emails = re.findall(r"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}", text)

    return emails


